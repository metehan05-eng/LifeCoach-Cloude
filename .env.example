# LifeCoach AI - Environment Variables

# ÇOKLU GEMINI API KEY SISTEMI
# Birden fazla API key tanımlayarak kota yedeklemesi yapabilirsiniz
# Key'ler sırasıyla kullanılır - birinin kota dolduğunda otomatik olarak bir sonraki kullanılır

# ANA API KEY (GEMINI_API_KEY_1 ile aynı işlev)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# API Key nasıl alınır:
# 1. https://makersuite.google.com/app/apikey adresine gidin
# 2. Google hesabınızla giriş yapın
# 3. "Create API Key" butonuna tıklayın
# 4. Oluşan key'i kopyalayın

# Varsayılan model
GEMINI_MODEL="gemini-2.0-flash"

# JWT Secret
JWT_SECRET="gizli-anahtar-degistir"

# Supabase (opsiyonel - yerel depolama kullanılıyorsa gerekli değil)
SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE"

# YouTube API (opsiyonel)
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY_HERE"

# Google service account JSON içeriği (tek satır halinde)
# Slides, Sheets, Calendar, Drive, Gmail, Vision API'leri bu hesap üzerinden çalışır
GOOGLE_SERVICE_ACCOUNT="{\"type\":\"service_account\",...}"
# Domain-wide delegation için yetkilendirilmiş kullanıcı e-posta
GOOGLE_DELEGATED_USER="user@example.com"
GOOGLE_GMAIL_USER="user@example.com"
GOOGLE_CALENDAR_USER="user@example.com"
GOOGLE_DRIVE_USER="user@example.com"
# Google Cloud Text-to-Speech API Key
GOOGLE_TTS_API_KEY="YOUR_GOOGLE_TTS_API_KEY_HERE"
# Google Maps JavaScript/Places API Key (tek API key gerektiren servis)
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY_HERE"

# Pexels API (Görsel Kartları)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY="YOUR_PEXELS_API_KEY_HERE"
