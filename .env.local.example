# ⚙️ Local Development Environment Variables
# Copy this file to .env.local and fill in your actual credentials
# WARNING: Never commit .env.local to git!

DATABASE_URL=""
NEXTAUTH_SECRET="BURAYA_RANDOM_STRING_KOY"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# ===== GOOGLE OAUTH =====
# Get from: https://console.cloud.google.com/
# Steps:
#   1. Go to APIs & Services → Credentials
#   2. Create OAuth 2.0 Client IDs (Web application)
#   3. Add Authorized redirect URIs:
#      - http://localhost:3004/api/auth/callback/google
#      - http://localhost:3000/api/auth/callback/google
#   4. Copy the Client ID and Client Secret
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET_HERE"

# ===== GEMINI API =====
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ===== OPENAI (Optional) =====
OPENAI_API_KEY=""

# ===== GITHUB OAUTH (Optional) =====
NEXT_PUBLIC_GITHUB_ID=""
NEXT_PUBLIC_GITHUB_SECRET=""

# ===== AWS S3 (Optional) =====
NEXT_PUBLIC_AMAZON_S3_BUCKET_NAME=""
NEXT_PUBLIC_AMAZON_S3_ACCESS_KEY_ID=""
NEXT_PUBLIC_AMAZON_S3_SECRET_ACCESS_KEY=""

# ===== METAL.IO (Optional) =====
METAL_API_KEY=""
METAL_APP_ID=""
METAL_INDEX_ID=""
METAL_CLIENT_ID=""

# ===== JWT TOKEN =====
# Generate a random string: `openssl rand -base64 32`
JWT_SECRET="BURAYA_RANDOM_STRING_KOY"

# ===== SUPABASE DATABASE =====
# Get from: https://app.supabase.com/
# Steps:
#   1. Go to your project
#   2. Settings → API
#   3. Copy Project URL (SUPABASE_URL)
#   4. Copy anon public key (SUPABASE_KEY / SUPABASE_ANON_KEY)
#   5. Copy service_role secret (SUPABASE_SERVICE_ROLE_KEY)
SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"
SUPABASE_KEY="YOUR_SUPABASE_ANON_KEY_HERE"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE"

# ===== OPENROUTER (Alternative AI) =====
OPENROUTER_API_KEY=""
