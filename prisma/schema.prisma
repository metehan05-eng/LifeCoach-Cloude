// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String?                 @unique
  emailVerified           DateTime?
  password                String?
  image                   String?
  
  // Gamification System
  xp                      Int                     @default(0)
  level                   Int                     @default(1)
  totalXp                 Int                     @default(0)
  han_coins               Int                     @default(0)
  isPremium               Boolean                 @default(false)
  currentStreak           Int                     @default(0)
  maxStreak               Int                     @default(0)
  lastActiveAt            DateTime?

  // Subscription & Usage System
  plan                    String                  @default("FREE") // FREE, PRO, ELITE
  usageLimit              Int                     @default(10)
  usageCount              Int                     @default(0)
  premiumExpiresAt        DateTime?

  inventory               UserItem[]
  
  accounts                Account[]
  sessions                Session[]
  PromptTemplate          PromptTemplate[]
  Chatbot                 Chatbot[]
  Chat                    Chat[]
  Datasource              Datasource[]
  ConversationMemories    ConversationMemory[]
  Achievements            Achievement[]
  Streaks                 Streak[]
  MotivationScores        MotivationScore[]
  DailyQuests             DailyQuest[]
  StudyGroups             StudyGroup[]
  OwnedGroups             StudyGroup[]            @relation("GroupOwner")
  AccountabilityPartner   AccountabilityPartner[]
  PartnerWith             AccountabilityPartner[] @relation("PartnerWith")
  Challenges              Challenge[]
  UserPreferences         UserPreference?
  AnalyticsLogs           AnalyticsLog[]
  NotificationPreferences NotificationPreference?
  Integrations            Integration[]
  Automations             Automation[]
  PushSubscriptions       PushSubscription[]
  Projects                Project[]
  GrowthDNA               GrowthDNA?
  StressLogs              StressLog[]
  GroupMemberships        GroupMember[]
  // HAN 4.2 Ultra Core Modules
  ModuleChatHistories     ModuleChatHistory[]
  Targets                 Target[]
  Productivities          Productivity[]
  Startups                Startup[]
  Decisions               Decision[]
}


model GrowthDNA {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @unique
  discipline  Int      @default(50) // 1-100
  focus       Int      @default(50)
  resilience  Int      @default(50)
  vision      Int      @default(50)
  traits      String[] // ["mükemmeliyetçi", "hızlı öğrenen", etc]
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model PromptTemplate {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  prompt    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  inputs    Json
  name      String
  Chatbot   Chatbot[]
}

model Datasource {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  url       String
  name      String
  type      String
  Chatbot   Chatbot[]
}

model Chatbot {
  id               Int              @id @default(autoincrement())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  promptTemplate   PromptTemplate?  @relation(fields: [promptTemplateId], references: [id])
  promptTemplateId Int?
  datasource       Datasource?      @relation(fields: [datasourceId], references: [id])
  datasourceId     Int?
  name             String
  ChatbotMessage   ChatbotMessage[]
}

model Chat {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("Yeni Sohbet")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  @@index([chatId])
}

model ChatbotMessage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbot   Chatbot? @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  chatbotId Int?
  message   String   @db.VarChar()
  agent     String
}

model ConversationMemory {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  conversationId String
  context        String   @db.Text
  keyPoints      Json
  emotionalState String?
  lastUpdated    DateTime @updatedAt
  @@index([userId])
}

model CoachingMode {
  id            String @id @default(cuid())
  name          String
  description   String @db.Text
  systemPrompt  String @db.Text
  tone          String
  responseStyle String
}

model UserPreference {
  id                   String   @id @default(cuid())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String   @unique
  selectedCoachingMode String   @default("Mentor")
  language             String   @default("tr")
  enableVoiceInput     Boolean  @default(true)
  enableVoiceOutput    Boolean  @default(true)
  darkMode             Boolean  @default(true)
  notificationsEnabled Boolean  @default(true)
  offlineMode          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Achievement {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  title         String
  description   String   @db.Text
  icon          String
  unlockedAt    DateTime @default(now())
  category      String
  points        Int      @default(0)
  createdAt     DateTime @default(now())
  @@index([userId])
}

model UserItem {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemType  String   // theme, title, boost, cosmetic
  name      String
  rarity    String   // common, rare, epic, legendary
  icon      String
  quantity  Int      @default(1)
  equipped  Boolean  @default(false)
  acquiredAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Streak {
  id              String    @id @default(cuid())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  habitId         String
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastCompletedAt DateTime?
  startedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@unique([userId, habitId])
  @@index([userId])
}

model MotivationScore {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  score           Int
  date            DateTime
  factors         Json
  aiInsights      String   @db.Text
  recommendations String   @db.Text
  createdAt       DateTime @default(now())
  @@unique([userId, date])
  @@index([userId, date])
}

model DailyQuest {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  title       String
  description String    @db.Text
  difficulty  String    @default("medium")
  xpReward    Int       @default(50)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  dueAt       DateTime
  @@index([userId, createdAt])
}

model StudyGroup {
  id           String        @id @default(cuid())
  name         String
  description  String        @db.Text
  owner        User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String
  members      GroupMember[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  subject      String?
  goalSharedId String?
  isPublic     Boolean       @default(true)
  User         User[]
  @@index([ownerId])
}

model GroupMember {
  id       String     @id @default(cuid())
  group    StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId  String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  joinedAt DateTime   @default(now())
  role     String     @default("member")
  @@unique([groupId, userId])
}

model AccountabilityPartner {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  partner   User     @relation("PartnerWith", fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String
  startedAt DateTime @default(now())
  status    String   @default("active")
  @@unique([userId, partnerId])
  @@index([userId])
}

model Challenge {
  id           String   @id @default(cuid())
  creator      User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId    String
  title        String
  description  String   @db.Text
  type         String
  duration     Int
  targetValue  Int
  currentValue Int      @default(0)
  startedAt    DateTime @default(now())
  endsAt       DateTime
  xpReward     Int      @default(200)
  isCompleted  Boolean  @default(false)
  difficulty   String   @default("medium")
  @@index([creatorId])
}

model AnalyticsLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     String
  metadata  Json
  timestamp DateTime @default(now())
  @@index([userId, timestamp])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String   @unique
  dailyReminders      Boolean  @default(true)
  motivationAlerts    Boolean  @default(true)
  habitReminders      Boolean  @default(true)
  goalUpdates         Boolean  @default(true)
  socialNotifications Boolean  @default(true)
  soundEnabled        Boolean  @default(true)
  optimalReminderTime String   @default("09:00")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Integration {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  type         String
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  connected    Boolean   @default(true)
  connectedAt  DateTime  @default(now())
  @@unique([userId, type])
}

model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}

model Automation {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  title       String
  time        String   // "20:00" format
  duration    Int      @default(30) // dakika
  repeat      String   @default("daily") // daily, weekly, etc
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastRunAt   DateTime?

  @@index([userId, time])
}

model Project {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  description String?  @db.Text
  status      String   @default("active") // active, completed, on_hold
  progress    Int      @default(0)
  category    String   @default("general")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deadline    DateTime?
  tags        String[]

  @@index([userId, status])
}

model StressLog {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  level           Int
  triggers        String[]
  context         String   @db.Text
  aiAnalysis      String   @db.Text
  recommendations String   @db.Text
  timestamp       DateTime @default(now())
  @@index([userId, timestamp])
}

// ─── HAN 4.2 Ultra Core – 4 Modül ───────────────────────────────────────────

/// Sohbet geçmişi – tüm modüller bu tabloya bağlıdır (session_id bağlantısı)
model ModuleChatHistory {
  id         String        @id @default(cuid())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  sessionId  String        @unique @default(cuid())
  moduleType String        // "target" | "productivity" | "startup" | "decision"
  messages   Json          // [{role: "user"|"assistant", content: "...", createdAt: "..."}]
  summary    String?       @db.Text
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // İlişkiler
  Target      Target[]
  Productivity Productivity[]
  Startup     Startup[]
  Decision    Decision[]

  @@index([userId, moduleType])
}

/// 🎯 Hedef Planla – Günde 1 hedef kısıtlaması (@@unique userId+date)
model Target {
  id            String            @id @default(cuid())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  chatHistory   ModuleChatHistory? @relation(fields: [chatHistoryId], references: [id])
  chatHistoryId String?
  targetText    String            @db.Text
  microSteps    Json              // [{id, text, completed, xpReward}]
  youtubeVideos Json?             // [{videoId, title, thumbnail, url}]
  targetDate    DateTime          @default(now())
  status        String            @default("aktif") // aktif | tamamlandı | beklemede
  xpEarned      Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Günlük benzersizlik: aynı kullanıcı aynı günde 1 hedef
  @@unique([userId, targetDate])
  @@index([userId, status])
}

/// ⚡ Üretkenlik Sistemi Kur
model Productivity {
  id             String            @id @default(cuid())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  chatHistory    ModuleChatHistory? @relation(fields: [chatHistoryId], references: [id])
  chatHistoryId  String?
  peakHours      String            // "09:00-12:00" gibi
  focusHours     Int               // günde kaç saat
  techniques     String[]          // ["Pomodoro", "Zaman Bloklama"]
  weeklySchedule Json              // [{day, blocks: [{start, end, task, type}]}]
  routines       Json?             // [{title, time, description}]
  status         String            @default("aktif") // aktif | tamamlandı | beklemede
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId, status])
}

/// 🚀 Startup Yol Haritası
model Startup {
  id              String            @id @default(cuid())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  chatHistory     ModuleChatHistory? @relation(fields: [chatHistoryId], references: [id])
  chatHistoryId   String?
  ideaDescription String            @db.Text
  mvpSteps        Json              // [{phase, title, tasks, duration, tools}]
  techStack       Json?             // {frontend, backend, database, deployment}
  marketAnalysis  Json?             // {tam, sam, som, competitors, advantages}
  currentPhase    Int               @default(0)
  status          String            @default("aktif") // aktif | tamamlandı | beklemede
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, status])
}

/// ⚖️ Karar Analizi
model Decision {
  id                String            @id @default(cuid())
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  chatHistory       ModuleChatHistory? @relation(fields: [chatHistoryId], references: [id])
  chatHistoryId     String?
  dilemma           String            @db.Text
  proConAnalysis    Json              // {pros: [{text, weight}], cons: [{text, weight}]}
  riskMatrix        Json?             // [{risk, probability, impact, mitigation}]
  timelineScenarios Json?             // {threeMonth, sixMonth, twelveMonth} senaryolar
  chosenOption      String?
  status            String            @default("aktif") // aktif | tamamlandı | beklemede
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId, status])
}

