// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String?                 @unique
  emailVerified           DateTime?
  password                String?
  image                   String?
  
  // Gamification System
  xp                      Int                     @default(0)
  level                   Int                     @default(1)
  totalXp                 Int                     @default(0)
  currentStreak           Int                     @default(0)
  maxStreak               Int                     @default(0)
  lastActiveAt            DateTime?

  accounts                Account[]
  sessions                Session[]
  PromptTemplate          PromptTemplate[]
  Chatbot                 Chatbot[]
  Datasource              Datasource[]
  ConversationMemories    ConversationMemory[]
  Achievements            Achievement[]
  Streaks                 Streak[]
  MotivationScores        MotivationScore[]
  DailyQuests             DailyQuest[]
  StudyGroups             StudyGroup[]
  OwnedGroups             StudyGroup[]            @relation("GroupOwner")
  AccountabilityPartner   AccountabilityPartner[]
  PartnerWith             AccountabilityPartner[] @relation("PartnerWith")
  Challenges              Challenge[]
  UserPreferences         UserPreference?
  AnalyticsLogs           AnalyticsLog[]
  NotificationPreferences NotificationPreference?
  Integrations            Integration[]
  Automations             Automation[]
  StressLogs              StressLog[]
  GroupMemberships        GroupMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model PromptTemplate {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  prompt    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  inputs    Json
  name      String
  Chatbot   Chatbot[]
}

model Datasource {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  url       String
  name      String
  type      String
  Chatbot   Chatbot[]
}

model Chatbot {
  id               Int              @id @default(autoincrement())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  promptTemplate   PromptTemplate?  @relation(fields: [promptTemplateId], references: [id])
  promptTemplateId Int?
  datasource       Datasource?      @relation(fields: [datasourceId], references: [id])
  datasourceId     Int?
  name             String
  ChatbotMessage   ChatbotMessage[]
}

model ChatbotMessage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chatbot   Chatbot? @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  chatbotId Int?
  message   String   @db.VarChar()
  agent     String
}

model ConversationMemory {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  conversationId String
  context        String   @db.Text
  keyPoints      Json
  emotionalState String?
  lastUpdated    DateTime @updatedAt
  @@index([userId])
}

model CoachingMode {
  id            String @id @default(cuid())
  name          String
  description   String @db.Text
  systemPrompt  String @db.Text
  tone          String
  responseStyle String
}

model UserPreference {
  id                   String   @id @default(cuid())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String   @unique
  selectedCoachingMode String   @default("Mentor")
  language             String   @default("tr")
  enableVoiceInput     Boolean  @default(true)
  enableVoiceOutput    Boolean  @default(true)
  darkMode             Boolean  @default(true)
  notificationsEnabled Boolean  @default(true)
  offlineMode          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Achievement {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  title         String
  description   String   @db.Text
  icon          String
  unlockedAt    DateTime @default(now())
  category      String
  points        Int      @default(0)
  createdAt     DateTime @default(now())
  @@index([userId])
}

model Streak {
  id              String    @id @default(cuid())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  habitId         String
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastCompletedAt DateTime?
  startedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@unique([userId, habitId])
  @@index([userId])
}

model MotivationScore {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  score           Int
  date            DateTime
  factors         Json
  aiInsights      String   @db.Text
  recommendations String   @db.Text
  createdAt       DateTime @default(now())
  @@unique([userId, date])
  @@index([userId, date])
}

model DailyQuest {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  title       String
  description String    @db.Text
  difficulty  String    @default("medium")
  xpReward    Int       @default(50)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  dueAt       DateTime
  @@index([userId, createdAt])
}

model StudyGroup {
  id           String        @id @default(cuid())
  name         String
  description  String        @db.Text
  owner        User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String
  members      GroupMember[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  subject      String?
  goalSharedId String?
  isPublic     Boolean       @default(true)
  User         User[]
  @@index([ownerId])
}

model GroupMember {
  id       String     @id @default(cuid())
  group    StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId  String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  joinedAt DateTime   @default(now())
  role     String     @default("member")
  @@unique([groupId, userId])
}

model AccountabilityPartner {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  partner   User     @relation("PartnerWith", fields: [partnerId], references: [id], onDelete: Cascade)
  partnerId String
  startedAt DateTime @default(now())
  status    String   @default("active")
  @@unique([userId, partnerId])
  @@index([userId])
}

model Challenge {
  id           String   @id @default(cuid())
  creator      User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId    String
  title        String
  description  String   @db.Text
  type         String
  duration     Int
  targetValue  Int
  currentValue Int      @default(0)
  startedAt    DateTime @default(now())
  endsAt       DateTime
  xpReward     Int      @default(200)
  isCompleted  Boolean  @default(false)
  difficulty   String   @default("medium")
  @@index([creatorId])
}

model AnalyticsLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  event     String
  metadata  Json
  timestamp DateTime @default(now())
  @@index([userId, timestamp])
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String   @unique
  dailyReminders      Boolean  @default(true)
  motivationAlerts    Boolean  @default(true)
  habitReminders      Boolean  @default(true)
  goalUpdates         Boolean  @default(true)
  socialNotifications Boolean  @default(true)
  soundEnabled        Boolean  @default(true)
  optimalReminderTime String   @default("09:00")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Integration {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  type         String
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  connected    Boolean   @default(true)
  connectedAt  DateTime  @default(now())
  @@unique([userId, type])
}

model Automation {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  title       String
  time        String   // "20:00" format
  duration    Int      @default(30) // dakika
  repeat      String   @default("daily") // daily, weekly, etc
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastRunAt   DateTime?

  @@index([userId, time])
}

model StressLog {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  level           Int
  triggers        String[]
  context         String   @db.Text
  aiAnalysis      String   @db.Text
  recommendations String   @db.Text
  timestamp       DateTime @default(now())
  @@index([userId, timestamp])
}
